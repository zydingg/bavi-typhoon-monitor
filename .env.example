# Express API port.
PORT=8787

# QWeather API key. Keep the real value only in the ignored .env file.
QWEATHER_API_KEY=

# Required QWeather API host assigned to this deployment. Do not use a public fallback.
QWEATHER_API_HOST=https://your-qweather-api-host.example.com

# Seconds between server-owned upstream refreshes. Defaults to 600 (10 minutes).
TYPHOON_REFRESH_SECONDS=600
