# Express API port.
PORT=8787

# Zhejiang Typhoon Portal endpoint, fetched at startup and then periodically by the server.
TYPHOON_API_URL=https://typhoon.slt.zj.gov.cn/Api/TyphoonList/Default

# Seconds between server-owned upstream refreshes. Defaults to 600 (10 minutes).
TYPHOON_REFRESH_SECONDS=600

# Seniverse current-weather API key. Keep the actual value only in the ignored .env file.
SENIVERSE_API_KEY=
