# Express API port.
PORT=8787

# QWeather credentials. Keep real values only in the ignored .env file.
QWEATHER_CREDENTIAL_ID=
QWEATHER_API_KEY=

# Optional QWeather API host override for approved test environments.
# QWEATHER_API_HOST=https://devapi.qweather.com

# Seconds between server-owned upstream refreshes. Defaults to 600 (10 minutes).
TYPHOON_REFRESH_SECONDS=600
